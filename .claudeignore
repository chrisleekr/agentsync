# .claudeignore — paths Claude Code should NOT read into context.
# Distinct from .gitignore: this targets files that are cheap to commit
# but expensive (noisy or binary) to feed into an LLM context window.

# ─── Dependencies & build output ───────────────────────────────────────
node_modules/
dist/
build/
coverage/

# ─── Lock files (committed, but huge and low-signal for Claude) ────────
bun.lock
package-lock.json
yarn.lock
pnpm-lock.yaml

# ─── Logs & OS cruft ───────────────────────────────────────────────────
*.log
.DS_Store
*.swp
*.tmp

# ─── Local test fixtures (ephemeral, regenerated by the test suite) ───
.agentsync-test-tmp/
trials/
.plan

# ─── Binary assets with no textual signal ──────────────────────────────
docs/agentsync-logo.png

# ─── Spec Kit ephemeral caches ─────────────────────────────────────────
.specify/extensions/.cache/
.specify/extensions/.backup/
.specify/extensions/*/local-config.yml

# ─── IDE / editor metadata ─────────────────────────────────────────────
.idea/
*.iml