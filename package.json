{
  "name": "agentsync",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "agentsync": "src/cli.ts"
  },
  "scripts": {
    "build": "bun build --compile src/cli.ts --outfile dist/agentsync",
    "typecheck": "bunx tsc --noEmit",
    "lint": "bunx biome ci .",
    "lint:fix": "bunx biome check --write .",
    "format": "bunx biome format .",
    "format:fix": "bunx biome format --write .",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "check": "bun run typecheck && bun run lint && bun run test",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "@iarna/toml": "^2.2.5",
    "age-encryption": "^0.3.0",
    "citty": "^0.2.2",
    "simple-git": "^3.27.0",
    "tar": "^7.4.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@types/node": "^22.15.3",
    "bun-types": "^1.3.9",
    "lefthook": "^2.1.4",
    "typescript": "^6.0.0"
  }
}
